# Neo4j (local Neo4j Desktop)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=changeme
NEO4J_DATABASE=neo4j

# LLM provider: openai | anthropic | ollama
# Using Groq via OpenAI-compatible API (free tier, fast)
LLM_PROVIDER=openai
LLM_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=gsk_your_groq_key_here
OPENAI_BASE_URL=https://api.groq.com/openai/v1

# Embeddings: fastembed | sentence-transformers | openai
# Groq does not serve embeddings — keep local
# fastembed avoids HuggingFace CDN (different download source; works when HF is blocked)
EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional alternative provider
ANTHROPIC_API_KEY=

# OpenAlex polite pool (recommended)
OPENALEX_USER_AGENT_EMAIL=your-email@example.com

# Ingestion tuning
MAX_PAPERS_PER_SEED=500
MAX_CITATION_DEPTH=1
BATCH_EMBEDDING_SIZE=32
